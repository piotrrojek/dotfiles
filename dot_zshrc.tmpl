# ---------------------------------------------------------------------------
# PATH
# ---------------------------------------------------------------------------
export GOPATH=$HOME/go
export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"
export PATH="$PATH:$GOPATH/bin"
export PATH="$PATH:$HOME/.krew/bin"   # kubectl krew plugins

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
export EDITOR="zed --wait"
export VISUAL="$EDITOR"
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
export WHISPER_MODEL="${WHISPER_MODEL:-$HOME/whisper-models/ggml-large-v3-turbo.bin}"
# sops picks up this path automatically — no flags needed for sops -d / -e.
export SOPS_AGE_KEY_FILE="$HOME/.config/sops/age/keys.txt"

# ---------------------------------------------------------------------------
# Secrets (sourced from iCloud Keychain via chezmoi template)
# ---------------------------------------------------------------------------
export GITHUB_READ_PAT="{{ output "icloud-keychain" "get" "dotfiles/github-read-pat" "piotrrojek" | trim }}"
export GITHUB_PAT="{{ output "icloud-keychain" "get" "dotfiles/github-pat" "piotrrojek" | trim }}"
export HF_TOKEN="{{ output "icloud-keychain" "get" "dotfiles/huggingface-token" "piotrrojek" | trim }}"
export CLOUDFLARE_EMAIL="{{ output "icloud-keychain" "get" "dotfiles/cloudflare-email" "piotrrojek" | trim }}"
export CLOUDFLARE_API_KEY="{{ output "icloud-keychain" "get" "dotfiles/cloudflare-api-key" "piotrrojek" | trim }}"

# ---------------------------------------------------------------------------
# History
# ---------------------------------------------------------------------------
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=50000
export SAVEHIST=50000
setopt SHARE_HISTORY           # all sessions see each other's history live
setopt INC_APPEND_HISTORY      # append as commands run, not on shell exit
setopt HIST_IGNORE_ALL_DUPS    # drop prior duplicates of the same command
setopt HIST_IGNORE_SPACE       # don't record lines starting with a space
setopt HIST_REDUCE_BLANKS      # collapse multiple blanks before saving
setopt HIST_VERIFY             # `!!` expansion shows the line before running

# ---------------------------------------------------------------------------
# Shell options
# ---------------------------------------------------------------------------
setopt AUTO_CD                 # typing a bare directory name cds into it
setopt EXTENDED_GLOB           # ^, ~, # in globs
setopt INTERACTIVE_COMMENTS    # allow `#` comments on the command line
setopt NO_BEEP

# ---------------------------------------------------------------------------
# Key bindings (Ghostty / iTerm alt+arrow = word jumps, Ctrl+R = history)
# ---------------------------------------------------------------------------
bindkey '^[[1;3C' forward-word
bindkey '^[[1;3D' backward-word
bindkey '^[f'     forward-word
bindkey '^[b'     backward-word
bindkey '^R'      history-incremental-search-backward

# ---------------------------------------------------------------------------
# Completion
# ---------------------------------------------------------------------------
autoload -Uz compinit && compinit

# ---------------------------------------------------------------------------
# Modern CLI replacements (all guarded — fall back to coreutils if missing)
# ---------------------------------------------------------------------------
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --group-directories-first'
  alias ll='eza -lah --git --group-directories-first'
  alias lt='eza --tree --level=2 --git-ignore'
fi
if command -v bat >/dev/null 2>&1; then
  alias cat='bat --paging=never --style=plain'
  # `--paging=auto` variant for when you actually want a pager:
  alias batp='bat --paging=auto'
fi
command -v fd >/dev/null 2>&1 && alias find='fd'

# ---------------------------------------------------------------------------
# kubectl / kubectx aliases
# ---------------------------------------------------------------------------
# All k-aliases route through kubecolor when available (colorized output),
# falling back to plain kubectl if kubecolor isn't installed yet.
# Aliases expand $_kc at definition time, so later unsetting $_kc is safe.
if command -v kubecolor >/dev/null 2>&1; then
  _kc=kubecolor
else
  _kc=kubectl
fi
alias k="$_kc"
alias kg="$_kc get"
alias kgp="$_kc get pods"
alias kgs="$_kc get svc"
alias kgn="$_kc get nodes"
alias kgd="$_kc get deployments"
alias kga="$_kc get all"
alias kgns="$_kc get namespaces"
alias kd="$_kc describe"
alias kdp="$_kc describe pod"
alias kl="$_kc logs"
alias klf="$_kc logs -f"
alias kaf="$_kc apply -f"
alias kdel="$_kc delete"
alias kx="$_kc exec -it"
alias kctx="$_kc config current-context"
unset _kc
alias kc=kubectx
alias kn=kubens
compdef k=kubectl   # completion for `k` still comes from the real kubectl

# ---------------------------------------------------------------------------
# Transcription helpers (yt-dlp + whisper-cli)
# ---------------------------------------------------------------------------
yt_to_srt() {
  local url="$1"
  local output_base="$2"
  local language="${3:-en}"

  yt-dlp -x --audio-format wav --postprocessor-args "-ar 16000" -o "$output_base.wav" "$url"
  whisper-cli --language "$language" --model "$WHISPER_MODEL" --split-on-word --max-len 65 --output-vtt --output-file "$output_base" --file "$output_base.wav"
  rm "$output_base.wav"
}

file_to_srt() {
  local filepath="$1"
  local language="${2:-en}"

  local filename=$(basename "$filepath")
  local filename_no_ext="${filename%.*}"
  local output_base="$filename_no_ext"
  local temp_wav="$output_base.wav"

  ffmpeg -i "$filepath" -vn -acodec pcm_s16le -ar 16000 -ac 1 "$temp_wav"
  whisper-cli --language "$language" --model "$WHISPER_MODEL" --split-on-word --max-len 65 --output-vtt --output-file "$output_base" --file "$temp_wav"
  rm "$temp_wav"
}

# ---------------------------------------------------------------------------
# Local LLM serving (vllm-mlx)
# ---------------------------------------------------------------------------
vllm-gemma4() {
  vllm-mlx serve mlx-community/gemma-4-26b-a4b-it-4bit \
    --host 0.0.0.0 \
    --port 8001 \
    --reasoning-parser gemma4 \
    --enable-auto-tool-choice \
    --tool-call-parser gemma4 \
    "$@"
}

vllm-qwen3() {
  vllm-mlx serve mlx-community/Qwen3.6-35B-A3B-4bit \
    --host 0.0.0.0 \
    --port 8002 \
    --reasoning-parser qwen3 \
    --enable-auto-tool-choice \
    --tool-call-parser qwen3_coder \
    --max-tokens 65536 \
    --use-paged-cache \
    --cache-memory-percent 0.30 \
    --kv-cache-quantization \
    --kv-cache-quantization-bits 8 \
    "$@"
}

# ---------------------------------------------------------------------------
# LLM CLI wrappers (point claude / opencode at the local vllm-mlx servers)
# ---------------------------------------------------------------------------
claude-local() {
  env \
    ANTHROPIC_BASE_URL="http://mac-mini-piotr:8001" \
    ANTHROPIC_API_KEY=not-needed \
    ANTHROPIC_MODEL=mlx-community/gemma-4-26b-a4b-it-4bit \
    ANTHROPIC_SMALL_FAST_MODEL=mlx-community/gemma-4-26b-a4b-it-4bit \
    claude "$@"
}

claude-qwen3() {
  env \
    ANTHROPIC_BASE_URL="http://mac-mini-piotr:8002" \
    ANTHROPIC_API_KEY=not-needed \
    ANTHROPIC_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit \
    ANTHROPIC_SMALL_FAST_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit \
    claude "$@"
}

opencode-qwen3() {
  opencode -m vllm-mlx/mlx-community/Qwen3.6-35B-A3B-4bit "$@"
}

# ---------------------------------------------------------------------------
# Infra shortcuts
# ---------------------------------------------------------------------------
headscale() {
  kubectl -n headscale exec -i headscale-0 -- headscale "$@"
}

# ---------------------------------------------------------------------------
# Third-party integrations (fzf, zoxide, direnv)
# ---------------------------------------------------------------------------
# fzf: Ctrl+R fuzzy history, Ctrl+T file picker, Alt+C cd picker
command -v fzf >/dev/null 2>&1 && source <(fzf --zsh)

# zoxide: smarter `cd` based on frecency — `z <substr>` jumps to best match,
# `zi` opens an fzf picker over your history of visited dirs.
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh --cmd z)"

# direnv: auto-load .envrc when cd'ing into a project
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook zsh)"

# ---------------------------------------------------------------------------
# Prompt
# ---------------------------------------------------------------------------
if [[ -z "$SSH_CONNECTION" && -z "$SSH_TTY" ]]; then
    eval "$(starship init zsh)"
fi
